specification {
  element container {
    style {
      shape rectangle
    }
  }
  element command {
    style {
      shape rectangle
      color muted
    }
  }
  element module {
    style {
      shape rectangle
      color slate
    }
  }
  element function {
    style {
      shape rectangle
      color gray
    }
  }
  element file {
    style {
      shape storage
      color amber
    }
  }
}

model {
  extend yahr {
    cli = container 'YAHR CLI' {
      description 'CLI app.'
      technology 'Python · Typer · Rich'

      convertCmd = command 'convert' {
        description 'Converts a PDF resume to Markdown in output/<stem>.md: markitdown extracts the raw text, then one OpenRouter LLM pass repairs the reading order, drops glyph artifacts, and applies Markdown structure.'
        technology 'markitdown · OpenRouter'
      }

      serveAgentCmd = command 'serve' {
        description 'Runs one A2A agent (job-searcher, ranker, cv-assistant) or job-provider MCP server (adzuna-mcp, mock-mcp) until Ctrl-C. The AGENT arg defaults to job-searcher; an unknown name lists the available servers and exits non-zero.'
      }

      helloCmd = command 'hello' {
        description 'Prints a welcome panel.'
        technology 'Rich'
      }

      askCmd = command 'ask' {
        description 'Routes a natural-language query to the best running agent through the orchestrator, streams the task status as it arrives, and renders the result: found jobs as cards, any other agent reply as Markdown. Attaches output/resume.md when the file exists, and lets the orchestrator decide per query whether to use it.'
        technology 'a2a-sdk client · httpx'
      }

    }
  }

  // How the user reaches each command from the terminal.
  user -> cli.convertCmd 'yahr convert cv.pdf'
  user -> cli.serveAgentCmd 'yahr serve job-searcher'
  user -> cli.helloCmd 'yahr hello'
  user -> cli.askCmd 'yahr ask "python developer jobs in milano"'

  // The resume file (defined in YAHR.c4 inside the yahr system) the CLI touches.
  cli.convertCmd -> yahr.resumeFile 'Writes output/<stem>.md'
  cli.askCmd -> yahr.resumeFile 'Reads the resume to attach (if present)'
}

views {
  view cliInterface of cli {
    title 'YAHR CLI: Commands'

    include *

    autoLayout TopBottom
  }
}
