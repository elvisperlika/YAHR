specification {
  element person {
    style {
      shape person
    }
  }
  element system
  element agent {
    style {
      shape person
      color green
    }
  }
  element mcpServer {
    style {
      shape rectangle
      color indigo
    }
  }
  element externalSystem {
    style {
      color secondary
    }
  }
}

model {
  user = person 'User' {
    description 'Runs the CLI to parse a resume, find matching jobs, and get improvement suggestions.'
  }

  yahr = system 'YAHR' {
    description 'Personal HR assistant CLI: parses a resume PDF, searches for matching jobs, and suggests resume improvements.'

    // The `cli` container is defined in CLI.c4 (extend yahr). The A2A agents and
    // the job-provider MCP servers the CLI orchestrates are defined here.

    orchestrator = agent 'Orchestrator Agent' {
      description 'Routes each query to the best agent: it discovers the running agents over A2A by fetching their Agent Cards, asks an LLM which one fits, forwards the message, and streams the result back. It caches the found jobs and the attached resume between runs so a ranking query can reuse them. The CLI runs it in-process today; the standalone served Orchestrator on its own port is still planned.'
      technology 'A2A client, OpenAI client, httpx'
    }

    jobSearcher = agent 'Job Searcher Agent' {
      description 'Searches a job-provider MCP server (Adzuna or the offline mock) for open positions matching a natural-language query, deduping the results and broadening the query over a few rounds until it has enough or hits its call budget.'
      technology 'A2A, MCP client, Starlette/uvicorn'
    }

    ranker = agent 'Ranker Agent' {
      description 'Scores each found job against the resume (0-100), ranks them best first, and answers which fit and why. Pinned to greedy, seeded sampling so the same input ranks the same way every run.'
      technology 'A2A, OpenAI client, Starlette/uvicorn'
    }

    cvAssistant = agent 'CV Assistant Agent' {
      description 'Analyzes the gap between the resume and one job the user names, then suggests concrete ways to strengthen the resume for it: missing skills, keywords to add, bullets to reword or quantify. Advisory only; it may flag skills the resume lacks, but it does not rewrite the resume.'
      technology 'A2A, OpenAI client, Starlette/uvicorn'
    }

    adzunaMcp = mcpServer 'Adzuna MCP Server' {
      description 'Wraps the Adzuna job board behind a generic search(query) tool over MCP. Fetches matching postings, then enriches each by retrieving its listing page for the full description.'
      technology 'MCP (FastMCP), httpx'
    }

    mockMcp = mcpServer 'Mock MCP Server' {
      description 'Serves canned jobs through the same search(query) tool as Adzuna, so the pipeline can run offline without credentials.'
      technology 'MCP (FastMCP)'
    }

    resumeFile = file 'output/resume.md' {
      description 'The converted resume in Markdown, used as shared memory: convert writes it, ask reads it to attach, and the orchestrator caches and reuses it across runs.'
    }

    jobsFile = file 'output/jobs.md' {
      description 'The orchestrator cache of the last job search, so a ranking or improvement query reuses those jobs instead of searching again.'
    }
  }

  openrouter = externalSystem 'OpenRouter' {
    description 'LLM gateway (OpenAI-compatible API) for LLM reasoning.'
  }

  jobApis = externalSystem 'Job Board API (Adzuna)' {
    description 'External job listing provider; the Adzuna MCP server queries it for open positions and fetches the listing pages.'
  }

  // System Context relationships
  user -> yahr 'Get resume parsing, job search, and improvement suggestions.'
  yahr -> openrouter 'Reasons over resume & jobs via LLM (HTTPS / JSON)'
  yahr -> jobApis 'Fetches open job listings from (HTTPS)'

  // Container relationships (cli is defined in CLI.c4)
  yahr.cli -> orchestrator 'Runs the orchestrator for each `ask` query'

  orchestrator -> jobSearcher 'Requests matching jobs (A2A)'
  orchestrator -> ranker 'Requests job scoring (A2A)'
  orchestrator -> cvAssistant 'Requests resume-gap analysis (A2A)'

  orchestrator -> openrouter 'Picks the best agent for each query via LLM (HTTPS / JSON)'
  jobSearcher -> adzunaMcp 'Searches jobs via the search tool (MCP)'
  jobSearcher -> mockMcp 'Offline alternative for the same search tool (MCP)'
  adzunaMcp -> jobApis 'Searches Adzuna & fetches listing pages (HTTPS)'
  ranker -> openrouter 'Scores jobs against the profile (HTTPS / JSON)'
  cvAssistant -> openrouter 'Analyzes the resume gap via LLM (HTTPS / JSON)'

  // Local files the system uses as memory between runs.
  orchestrator -> jobsFile 'Caches the found jobs, reloads them next run (read/write)'
  orchestrator -> resumeFile 'Caches and reuses the attached resume (read/write)'
}

views {
  view index {
    title 'YAHR: System Context'

    include user, yahr, openrouter, jobApis

    autoLayout TopBottom
  }

  view containers of yahr {
    title 'YAHR: Containers'

    include *

    autoLayout TopBottom
  }
}
