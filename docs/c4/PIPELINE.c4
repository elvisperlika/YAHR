views {
  dynamic view pipeline {
    title 'YAHR: Ask Pipeline'
    description '''
      One `ask` query, end to end. The CLI runs the orchestrator in-process: it
      discovers the running agents over A2A, asks the LLM which one fits, forwards
      the query, and streams the result back. Shown here for a plain job search;
      a ranking or resume-gap query routes to the ranker or CV Assistant instead
      and reuses the jobs the searcher cached (see the sequence view).
    '''

    yahr.cli -> yahr.orchestrator 'ask "<query>" (attaches output/resume.md if present)'

    // Discover the running agents by fetching their Agent Cards.
    parallel {
      yahr.orchestrator -> yahr.jobSearcher 'GET agent card (A2A)'
      yahr.orchestrator -> yahr.ranker 'GET agent card (A2A)'
      yahr.orchestrator -> yahr.cvAssistant 'GET agent card (A2A)'
    }

    yahr.orchestrator -> openrouter 'Which agent fits the query? (LLM)'
    yahr.orchestrator -> yahr.jobSearcher 'Forward the query (A2A, streaming)'
    yahr.jobSearcher -> yahr.adzunaMcp 'search(query) (MCP)'
    yahr.adzunaMcp -> jobApis 'Search & fetch listing pages (HTTPS)'
    yahr.jobSearcher -> yahr.orchestrator 'Found jobs (A2A artifact)'
    yahr.orchestrator -> yahr.jobsFile 'Cache the jobs artifact (output/jobs.md)'
    yahr.orchestrator -> yahr.cli 'Stream status, then render job cards'

    autoLayout LeftRight
  }

  dynamic view rankFlow {
    variant sequence

    title 'YAHR: Ranking Query'
    description '''
      A ranking or resume-gap query. The orchestrator reuses the jobs the Job
      Searcher cached on an earlier run, only searching first when the cache is
      empty, then bundles the question, those jobs, and the resume for the ranker
      (the CV Assistant follows the same shape for gap analysis). There is no
      automatic rewrite loop: the CV Assistant returns advice and the user edits
      the resume themselves.
    '''

    yahr.cli -> yahr.resumeFile 'Read output/resume.md'
    yahr.cli -> yahr.orchestrator 'ask "which job fits me?" + resume'
    yahr.orchestrator -> openrouter 'Route the query (LLM)'
    yahr.orchestrator -> yahr.jobsFile 'Load the cached jobs'
    yahr.orchestrator -> yahr.jobSearcher 'Search first only if the cache is empty' {
      notes '''
        The orchestrator caches the Job Searcher results between `ask` runs. A
        ranking query reuses that cache and searches here only when nothing has
        been searched yet.
      '''
    }
    yahr.jobSearcher -> yahr.orchestrator 'Jobs (A2A artifact)'
    yahr.orchestrator -> yahr.jobsFile 'Cache the jobs artifact (write)'
    yahr.orchestrator -> yahr.ranker 'Bundle question + jobs + resume (A2A)'
    yahr.ranker -> openrouter 'Score & rank against the resume (LLM, seeded)'
    yahr.ranker -> yahr.orchestrator 'Ranked jobs + answer'
    yahr.cli <- yahr.orchestrator 'Stream status, then render Markdown'
  }

  dynamic view improveFlow {
    variant sequence

    title 'YAHR: Resume Improvement Query'
    description '''
      The user asks how to strengthen their resume for one specific job. The
      orchestrator routes to the CV Assistant, reusing the jobs the Job Searcher
      cached (searching first only when the cache is empty), then bundles the
      request, those jobs, and the resume. The CV Assistant names the target job,
      compares it against the resume, and returns a gap report with concrete
      suggestions. It is advisory: it never rewrites the resume, so the user makes
      the edits themselves.
    '''

    yahr.cli -> yahr.resumeFile 'Read output/resume.md'
    yahr.cli -> yahr.orchestrator 'ask "improve my resume for <job>" + resume'
    yahr.orchestrator -> openrouter 'Route the query (LLM)'
    yahr.orchestrator -> yahr.jobsFile 'Load the cached jobs'
    yahr.orchestrator -> yahr.jobSearcher 'Search first only if the cache is empty' {
      notes '''
        Same jobs cache as the ranking flow: the orchestrator reuses the Job
        Searcher results from an earlier `ask` and searches here only when nothing
        has been searched yet.
      '''
    }
    yahr.jobSearcher -> yahr.orchestrator 'Jobs (A2A artifact)'
    yahr.orchestrator -> yahr.jobsFile 'Cache the jobs artifact (write)'
    yahr.orchestrator -> yahr.cvAssistant 'Bundle request + jobs + resume (A2A)'
    yahr.cvAssistant -> openrouter 'Gap analysis vs the chosen job (LLM, seeded)' {
      notes '''
        One LLM call: pick the single job named in the request, compare it against
        the resume, and emit a "## Gaps" section (each gap marked REWORD or
        ACQUIRE) plus a "## Suggestions" section. It only claims the user already
        has something when that fact is present in the resume.
      '''
    }
    yahr.cvAssistant -> yahr.orchestrator 'Gaps + suggestions (Markdown)'
    yahr.cli <- yahr.orchestrator 'Stream status, then render Markdown'
  }
}
